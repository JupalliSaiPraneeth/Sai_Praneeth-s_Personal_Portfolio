# Server port
PORT=3000

# SMTP settings (example shown for Gmail; you can also use SendGrid/Mailgun/etc.)
# If using Gmail, prefer an App Password (not your main password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Where messages should be delivered
CONTACT_TO_EMAIL=your_email@gmail.com

# Optional: what address the email appears to come from
# If omitted, CONTACT_TO_EMAIL is used.
CONTACT_FROM_EMAIL=your_email@gmail.com
